# --- Dependencies ---
# Never commit the massive node_modules folder; it can be re-installed via npm/yarn/pnpm.
node_modules/
jspm_packages/
web_modules/

# --- Environment & Secrets ---
# CRITICAL: Security risk. Sensitive credentials, API keys, and database URLs live here.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
config.json
*.pem
*.key

# --- Build & Compiled Code ---
# If you are using TypeScript or a bundler (like esbuild/swc), ignore the output directories.
dist/
build/
out/
*.tsbuildinfo

# --- Logs ---
# Server logs, crash reports, and npm activity tracking files.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testing & Coverage ---
# Test coverage reports generated by Jest, Mocha, or Istanbul.
coverage/
.nyc_output/
.jest/

# --- Database & Storage ---
# Local SQLite databases, local uploads, or temporary storage folders.
*.db
*.sqlite
uploads/
storage/
tmp/
.local-storage/

# --- IDEs & Code Editors ---
# Editor-specific configurations that shouldn't be forced on other developers.
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- Diagnostic & OS Files ---
# System-generated files that clutter repositories.
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini